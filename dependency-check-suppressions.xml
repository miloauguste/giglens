<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- FALSE POSITIVE: androidx.sqlite version number 2.4.0 misidentified as SQLite engine v2.4.0 -->
    <suppress>
        <notes>androidx.sqlite is the AndroidX wrapper library, not the SQLite engine. Version 2.4.0 is the wrapper version, not SQLite engine version.</notes>
        <packageUrl regex="true">^pkg:maven/androidx\.sqlite/.*$</packageUrl>
        <cpe>cpe:/a:sqlite:sqlite:2.4.0</cpe>
    </suppress>

    <!-- FALSE POSITIVE: sqlite-jdbc is OWASP's own internal tool dependency, not shipped in APK -->
    <suppress>
        <notes>sqlite-jdbc is used internally by the OWASP dependency-check tool itself, not included in the GigLens APK.</notes>
        <packageUrl regex="true">^pkg:maven/org\.xerial/sqlite-jdbc.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>

    <!-- FALSE POSITIVE: Kotlin build tools are compile-time only, not shipped in APK -->
    <suppress>
        <notes>Kotlin compiler/build tools are compile-time dependencies only. Not included in shipped APK.</notes>
        <packageUrl regex="true">^pkg:maven/org\.jetbrains\.kotlin/kotlin-(annotation-processing|build-|compiler|daemon|klib|script).*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>

    <!-- FALSE POSITIVE: room-compiler-processing version misread as Processing IDE version -->
    <suppress>
        <notes>room-compiler-processing version 2.6.1 misidentified as Processing IDE v2.6.1. These are unrelated projects.</notes>
        <packageUrl regex="true">^pkg:maven/androidx\.room/room-compiler-processing.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>

    <!-- FALSE POSITIVE: symbol-processing-api version misread as Processing IDE version -->
    <suppress>
        <notes>symbol-processing-api version misidentified as Processing IDE. These are unrelated projects.</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.devtools\.ksp/symbol-processing-api.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>

    <!-- KNOWN: guava transitive dependency from ML Kit - not used directly, monitor for update -->
    <suppress until="2026-12-01">
        <notes>Guava is a transitive dependency from ML Kit text-recognition. GigLens does not call Guava APIs directly. Monitor for ML Kit update that bumps Guava.</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.guava/guava.*$</packageUrl>
        <cve>CVE-2023-2976</cve>
    </suppress>

    <!-- FALSE POSITIVE: CVE-2020-29582 Kotlin createTempDir/createTempFile insecure permissions
         GigLens does not use createTempDir() or createTempFile(). Affects all Kotlin stdlib/reflect
         versions but only exploitable if those APIs are called directly. -->
    <suppress>
        <notes>GigLens does not use Kotlin createTempDir/createTempFile APIs.</notes>
        <packageUrl regex="true">^pkg:maven/org\.jetbrains\.kotlin/kotlin-(stdlib|reflect).*$</packageUrl>
        <cve>CVE-2020-29582</cve>
    </suppress>

    <!-- FALSE POSITIVE: CVE-2020-8908 Guava Files.createTempDir() insecure permissions (Low, CVSS 3.3)
         GigLens does not call Guava Files.createTempDir(). Transitive via play-services SDK. -->
    <suppress>
        <notes>GigLens does not use Guava Files.createTempDir(). Transitive via play-services.</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.guava/guava.*$</packageUrl>
        <cve>CVE-2020-8908</cve>
    </suppress>
    <!-- CVE-2022-3171, CVE-2024-7254: protobuf-javalite DoS via crafted binary messages
         Transitive via Firebase/datastore-preferences. GigLens does not parse untrusted
         protobuf data — protobuf used internally by Firebase SDK only.
         protobuf-javalite 3.25.5 forced in dependencies to patch where possible. -->
    <suppress>
        <notes>GigLens does not parse untrusted protobuf data. Transitive via Firebase. Patched version forced.</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf-javalite.*$</packageUrl>
        <cve>CVE-2022-3171</cve>
    </suppress>
    <suppress>
        <notes>GigLens does not parse untrusted protobuf data. Transitive via Firebase. Patched version forced.</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf-javalite.*$</packageUrl>
        <cve>CVE-2024-7254</cve>
    </suppress>
    <!-- CVE-2026-0994: protobuf Python-only DoS via json_format.ParseDict()
         This CVE affects the Python protobuf implementation only — not Java/Android.
         OWASP scanner false positive matching package name across ecosystems. -->
    <suppress>
        <notes>CVE-2026-0994 affects Python protobuf only — GigLens is Android/Kotlin, not affected.</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf-javalite.*$</packageUrl>
        <cve>CVE-2026-0994</cve>
    </suppress>
    <!-- CVE-2020-22475, CVE-2022-39349: kotlinx-coroutines-play-services misidentified
         OWASP scanner misidentifies kotlinx-coroutines-play-services as "tasks" package.
         These CVEs affect a different "tasks" project — not Kotlin coroutines. -->
    <suppress>
        <notes>False positive — kotlinx-coroutines-play-services misidentified as unrelated tasks package.</notes>
        <packageUrl regex="true">^pkg:maven/org\.jetbrains\.kotlinx/kotlinx-coroutines-play-services.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    <!-- CVE-2021-22569, CVE-2021-22570: protobuf-javalite DoS via crafted binary input
         Bundled in datastore-preferences-core pom — cannot be upgraded directly.
         GigLens does not parse untrusted protobuf data — not exploitable. -->
    <suppress>
        <notes>GigLens does not parse untrusted protobuf data. Bundled in datastore-preferences-core, cannot upgrade.</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf-javalite.*$</packageUrl>
        <cve>CVE-2021-22569</cve>
    </suppress>
    <suppress>
        <notes>GigLens does not parse untrusted protobuf data. Bundled in datastore-preferences-core, cannot upgrade.</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf-javalite.*$</packageUrl>
        <cve>CVE-2021-22570</cve>
    </suppress>
</suppressions>
