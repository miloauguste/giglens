<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginBottom="8dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/gl_bg_card">

    <!-- Vertical container: main row + (optional) town-confirmation strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main row -->
        <LinearLayout
            android:id="@+id/rowMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Verdict badge — background set programmatically -->
            <TextView
                android:id="@+id/tvVerdict"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <!-- Restaurant + meta -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tvRestaurant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/gl_text_primary"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/gl_text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Net value + time of day -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvNet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/gl_text_muted"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Town-confirmation strip — shown only when an estimated town exists.
             Driver confirms post-shift (the only time the true destination is known).
             Author: Claude (Anthropic) - 2026-06-30 -->
        <LinearLayout
            android:id="@+id/layoutTownConfirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="0dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvTownPrompt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:textSize="12sp"
                android:textColor="@color/gl_text_secondary"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Backgrounds set programmatically (rounded chips) -->
            <TextView
                android:id="@+id/btnTownYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Yes"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btnTownNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✗ No"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="7dp"
                android:paddingBottom="7dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
