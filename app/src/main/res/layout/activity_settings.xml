<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOCATION"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Use GPS for region"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnBackground"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Automatically detects your region for better distance estimates"
                            android:textSize="13sp"
                            android:textColor="#999999"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchGps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDetectedRegion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detected region: --"
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manual region (fallback if GPS off)"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnBackground"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Newark, New Jersey, USA"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCORING"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle cost per mile"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IRS standard is $0.90/mile. Adjust for your vehicle."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCostPerMile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Cost per mile ($)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCostPerMile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>


                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your hourly rate"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What your time is worth per hour. Used to calculate time cost per offer."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilHourlyRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Hourly rate ($)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHourlyRate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMMUNITY DATA"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share offer data"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Help other drivers by contributing anonymized offer data to community benchmarks."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <RadioGroup
                    android:id="@+id/rgDataSharing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbSharingNone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't share anything"/>

                    <RadioButton
                        android:id="@+id/rbSharingAggregate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share anonymized averages only"/>

                    <RadioButton
                        android:id="@+id/rbSharingIndividual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share individual offers (opted-in)"/>
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FLOATING WIDGET"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show floating widget"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnBackground"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Display offer results as a floating pill"
                            android:textSize="13sp"
                            android:textColor="#999999"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchWidget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWidgetPermStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Permission required: Draw over other apps"
                    android:textSize="12sp"
                    android:paddingTop="8dp"
                    android:textColor="#FF9800"/>

                <Button
                    android:id="@+id/btnGrantOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grant Permission"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
