<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOCATION"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Use GPS for region"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnBackground"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Automatically detects your region for better distance estimates"
                            android:textSize="13sp"
                            android:textColor="#999999"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchGps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDetectedRegion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detected region: --"
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manual region (fallback if GPS off)"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnBackground"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Newark, New Jersey, USA"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCORING"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle cost per mile"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IRS standard is $0.90/mile. Adjust for your vehicle."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCostPerMile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Cost per mile ($)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCostPerMile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>


                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your hourly rate"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What your time is worth per hour. Used to calculate time cost per offer."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilHourlyRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Hourly rate ($)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHourlyRate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VEHICLE FUEL COST"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle MPG"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fuel economy of your vehicle. Used to calculate real gas cost per offer."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLookupMpg"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Look up my MPG at fueleconomy.gov →"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMpg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="MPG (e.g. 32 for Honda Civic)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMpg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionNext"/>
                </com.google.android.material.textfield.TextInputLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gas price per gallon"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current gas price in your area. Update weekly for accurate cost estimates."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilGasPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Gas price ($/gallon)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etGasPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMMUNITY DATA"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share offer data"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Help other drivers by contributing anonymized offer data to community benchmarks."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <RadioGroup
                    android:id="@+id/rgDataSharing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbSharingNone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't share anything"/>

                    <RadioButton
                        android:id="@+id/rbSharingAggregate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share anonymized averages only"/>

                    <RadioButton
                        android:id="@+id/rbSharingIndividual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share individual offers (opted-in)"/>
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTO CAPTURE"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Capture mode"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How GigLens detects and analyzes offer screens."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <RadioGroup
                    android:id="@+id/rgCaptureMode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbCaptureOff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Off (manual share only)"/>

                    <RadioButton
                        android:id="@+id/rbCaptureAccessibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accessibility (fully automatic)"/>

                    <RadioButton
                        android:id="@+id/rbCaptureButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Floating button (tap to capture)"/>

                    <RadioButton
                        android:id="@+id/rbCaptureBoth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Both (auto + floating button)"/>

                </RadioGroup>

                <TextView
                    android:id="@+id/tvAccessibilityPermStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accessibility permission required"
                    android:textSize="12sp"
                    android:paddingTop="12dp"
                    android:textColor="#FF9800"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvAccessibilityActive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓ Accessibility service active"
                    android:textSize="12sp"
                    android:paddingTop="12dp"
                    android:textColor="#00E5A0"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btnGrantAccessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grant Accessibility Permission"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUPPORTED PLATFORMS"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select which apps GigLens monitors"
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="12dp"/>

                <CheckBox
                    android:id="@+id/cbPlatformDoordash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DoorDash"
                    android:enabled="true"/>

                <CheckBox
                    android:id="@+id/cbPlatformUbereats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uber Eats (coming soon)"
                    android:enabled="false"
                    android:textColor="#666666"/>

                <CheckBox
                    android:id="@+id/cbPlatformGrubhub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grubhub (coming soon)"
                    android:enabled="false"
                    android:textColor="#666666"/>

                <CheckBox
                    android:id="@+id/cbPlatformInstacart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Instacart (coming soon)"
                    android:enabled="false"
                    android:textColor="#666666"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FLOATING WIDGET"
            android:textSize="12sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show floating widget"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnBackground"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Display offer results as a floating pill"
                            android:textSize="13sp"
                            android:textColor="#999999"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchWidget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWidgetPermStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Permission required: Draw over other apps"
                    android:textSize="12sp"
                    android:paddingTop="8dp"
                    android:textColor="#FF9800"/>

                <Button
                    android:id="@+id/btnGrantOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grant Permission"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DDDDDD"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Result display duration"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seconds to show the result pill before it reverts to idle. Default 60."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilResultDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Duration (seconds)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etResultDuration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
