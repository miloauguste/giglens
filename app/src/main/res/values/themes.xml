<resources>
    <style name="Theme.GigLens" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#1B5E20</item>
        <item name="colorPrimaryVariant">#2E7D32</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#00C853</item>
        <item name="colorSecondaryVariant">#69F0AE</item>
        <item name="colorOnSecondary">#000000</item>
    </style>

    <!-- Transparent theme for share receiver — processes in background -->
    <style name="Theme.GigLens.Transparent" parent="Theme.GigLens">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
