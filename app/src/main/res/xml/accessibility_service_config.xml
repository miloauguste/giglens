<!-- Accessibility Service config for GigLens offer detection -->
<!--
    SECURITY POLICY:
    android:packageNames = OS-level hard filter. Android drops all events from
    packages not listed here before any Kotlin code runs.

    Phase 1  (active): DoorDash only
    Phase 2  (planned): + Uber Eats, Grubhub
    Phase 3  (planned): + Instacart, Amazon Flex, Shipt

    TO ADD A PLATFORM: add package here AND in PlatformRegistry.kt
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"

    android:accessibilityEventTypes="typeWindowContentChanged|typeWindowStateChanged"

    android:accessibilityFeedbackType="feedbackGeneric"

    android:accessibilityFlags="flagDefault|flagReportViewIds"

    android:canRetrieveWindowContent="true"

    android:description="@string/accessibility_service_description"

    android:notificationTimeout="500"

    android:packageNames="
        com.dd.doordash,
        com.ubereats.driver,
        com.grubhub.driver,
        com.instacart.shopper,
        com.amazon.rabbit,
        com.shipt.shopper" />
